{
    "name": "demeve/template",
    "description": "A PHP library to load and render view files split into named sections (output, style, script, etc.).",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Diego Mont",
            "email": "diegomontt@gmail.com",
            "role": "Developer"
        }
    ],
    "keywords": ["template", "view", "component", "sfc", "html", "sections"],
    "homepage": "https://github.com/demve/template",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "autoload": {
        "psr-4": {
            "Demeve\\Template\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Demeve\\Template\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable"
}
